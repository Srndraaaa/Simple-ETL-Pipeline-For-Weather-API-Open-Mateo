# PostgreSQL
POSTGRES_DB=etl_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=supersecret
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ETL settings
SCHEDULE_INTERVAL_HOURS=2
OPEN_METEO_LATITUDE=-6.2088
OPEN_METEO_LONGITUDE=106.8456
OPEN_METEO_HOURLY_FIELDS=temperature_2m,relative_humidity_2m,precipitation,wind_speed_10m
OPEN_METEO_TIMEOUT_SECONDS=30
OPEN_METEO_RETRIES=3
OPEN_METEO_BACKOFF_SECONDS=1
LOG_LEVEL=INFO